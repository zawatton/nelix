#!/bin/sh
set -eu

if [ -n "${NELIX_LISPDIR:-}" ]; then
  lispdir=$NELIX_LISPDIR
else
  self_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
  if [ -f "$self_dir/../scripts/nelix-cli.el" ]; then
    lispdir=$(CDPATH= cd -- "$self_dir/.." && pwd)
  elif [ -f "$self_dir/../share/emacs/site-lisp/nelix/scripts/nelix-cli.el" ]; then
    lispdir=$(CDPATH= cd -- "$self_dir/../share/emacs/site-lisp/nelix" && pwd)
  elif [ -f "/usr/share/emacs/site-lisp/elpa-src/nelix-0.1.0/nelix-cli.el" ]; then
    lispdir=/usr/share/emacs/site-lisp/elpa-src/nelix-0.1.0
  else
    lispdir=${NELIX_SYSTEM_LISPDIR:-/usr/local/share/emacs/site-lisp/nelix}
  fi
fi

if [ -f "$lispdir/scripts/nelix-cli.el" ]; then
  clifile=$lispdir/scripts/nelix-cli.el
elif [ -f "$lispdir/nelix-cli.el" ]; then
  clifile=$lispdir/nelix-cli.el
else
  clifile=$lispdir/scripts/nelix-cli.el
fi

nelix_lisp_file() {
  name=$1
  if [ -f "$lispdir/scripts/$name" ]; then
    printf '%s\n' "$lispdir/scripts/$name"
  elif [ -f "$lispdir/$name" ]; then
    printf '%s\n' "$lispdir/$name"
  else
    return 1
  fi
}

runtime=${NELIX_RUNTIME:-emacs}
if [ "${1:-}" = "--runtime" ]; then
  if [ -z "${2:-}" ]; then
    echo "nelix: --runtime requires emacs or nelisp" >&2
    exit 2
  fi
  runtime=$2
  shift 2
elif [ "${1:-}" = "--json" ] && [ "${2:-}" = "--runtime" ]; then
  if [ -z "${3:-}" ]; then
    echo "nelix: --runtime requires emacs or nelisp" >&2
    exit 2
  fi
  runtime=$3
  shift 3
  set -- --json "$@"
fi

nelix_quote_elisp_string() {
  if [ -z "$1" ]; then
    printf '""'
  else
    printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g; s/^/"/; s/$/"/'
  fi
}

nelix_find_nelisp() {
  if [ -n "${NELISP:-}" ]; then
    printf '%s\n' "$NELISP"
  elif command -v nelisp >/dev/null 2>&1; then
    command -v nelisp
  elif [ -x "$lispdir/../nelisp/target/nelisp" ]; then
    printf '%s\n' "$lispdir/../nelisp/target/nelisp"
  elif [ -x "$lispdir/../nelisp/target/debug/nelisp" ]; then
    printf '%s\n' "$lispdir/../nelisp/target/debug/nelisp"
  else
    return 1
  fi
}

nelix_nelisp_root() {
  if [ -n "${NELISP_ROOT:-}" ]; then
    printf '%s\n' "$NELISP_ROOT"
  elif [ -d "$lispdir/../nelisp/lisp" ]; then
    (CDPATH= cd -- "$lispdir/../nelisp" && pwd)
  else
    case "$1" in
      */target/nelisp|*/target/debug/nelisp)
        (CDPATH= cd -- "$(dirname -- "$(dirname -- "$1")")" && pwd)
        ;;
      *)
        return 1
        ;;
    esac
  fi
}

nelix_nelisp_direct_available() {
  nelisp_bin=$(nelix_find_nelisp) || return 1
  nelisp_root=$(nelix_nelisp_root "$nelisp_bin") || return 1
  smoke_file=$(nelix_lisp_file anvil-pkg-nelisp-smoke.el) || return 1
  ert_shim=$(nelix_lisp_file anvil-pkg-nelisp-ert-shim.el) || return 1
  test -f "$smoke_file" || return 1
  test -f "$ert_shim" || return 1
  test -f "${NELISP_STDLIB_EVAL_SPECIAL_SRC:-$nelisp_root/lisp/nelisp-stdlib-eval-special.el}" || return 1
  test -f "${NELISP_CL_MACROS_SRC:-$nelisp_root/lisp/nelisp-cl-macros.el}" || return 1
  test -f "${NELISP_JSON_SRC:-$nelisp_root/packages/nelisp-json/src/nelisp-json.el}" || return 1
  test -f "${NELISP_ACTOR_SRC:-$nelisp_root/packages/nelisp-actor/src/nelisp-actor.el}" || return 1
  test -f "${NELISP_PROCESS_SRC:-$nelisp_root/packages/nelisp-process/src/nelisp-process.el}" || return 1
  return 0
}

nelix_nelisp_cli_image_path() {
  if [ "${NELIX_NELISP_IMAGE:-}" = "none" ]; then
    return 1
  fi
  if [ -n "${NELIX_NELISP_IMAGE:-}" ]; then
    test -f "$NELIX_NELISP_IMAGE" || return 1
    printf '%s\n' "$NELIX_NELISP_IMAGE"
    return 0
  fi
  return 1
}

nelix_truthy() {
  case "${1:-}" in
    1|true|yes|on)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

nelix_nelisp_aot_cache_enabled() {
  case "${NELIX_NELISP_AOT:-auto}" in
    0|false|no|off|none|direct)
      return 1
      ;;
    *)
      return 0
      ;;
  esac
}

nelix_abs_path() {
  case "$1" in
    /*)
      printf '%s\n' "$1"
      ;;
    *)
      printf '%s/%s\n' "$(pwd)" "$1"
      ;;
  esac
}

nelix_emit_nelisp_suite_source_files() {
  cat <<EOF
(setq anvil-pkg-nelisp-smoke-suite-source-files
      (list
       $(nelix_quote_elisp_string "$lispdir/anvil-pkg-compat.el")
       $(nelix_quote_elisp_string "$lispdir/anvil-pkg-state.el")
       $(nelix_quote_elisp_string "$lispdir/anvil-pkg.el")
       $(nelix_quote_elisp_string "$lispdir/anvil-pkg-dsl.el")
       $(nelix_quote_elisp_string "$lispdir/anvil-pkg-import.el")
       $(nelix_quote_elisp_string "$lispdir/anvil-pkg-emacs.el")
       $(nelix_quote_elisp_string "$lispdir/nelix-store.el")
       $(nelix_quote_elisp_string "$lispdir/nelix-registry.el")
       $(nelix_quote_elisp_string "$lispdir/nelix-fetch.el")
       $(nelix_quote_elisp_string "$lispdir/nelix-builder.el")
       $(nelix_quote_elisp_string "$lispdir/nelix-backend.el")
       $(nelix_quote_elisp_string "$lispdir/nelix-manifest.el")
       $(nelix_quote_elisp_string "$lispdir/nelix-fast.el")
       $(nelix_quote_elisp_string "$lispdir/nelix-substitute.el")
       $(nelix_quote_elisp_string "$lispdir/nelix-dsl.el")
       $(nelix_quote_elisp_string "$lispdir/nelix-import.el")
       $(nelix_quote_elisp_string "$lispdir/nelix-emacs.el")
       $(nelix_quote_elisp_string "$lispdir/nelix.el")
       $(nelix_quote_elisp_string "$lispdir/scripts/anvil-pkg-render.el")))
EOF
}

nelix_default_profile_dir() {
  if [ -n "${XDG_STATE_HOME:-}" ]; then
    printf '%s/nelix/profile\n' "$XDG_STATE_HOME"
  else
    printf '%s/.local/state/nelix/profile\n' "${HOME:-$PWD}"
  fi
}

nelix_aot_cache_fresh_p() {
  manifest=$1
  cache=$2
  [ -f "$cache" ] || return 1
  if awk -F '	' '$1 == "source-file" { found = 1 } END { exit(found ? 0 : 1) }' "$cache"; then
    sources=$(mktemp "${TMPDIR:-/tmp}/nelix-aot-sources.XXXXXX")
    awk -F '	' '$1 == "source-file" && $2 != "" { print $2 }' "$cache" >"$sources"
    while IFS= read -r source_file; do
      [ -f "$source_file" ] || {
        rm -f "$sources"
        return 1
      }
      if [ "$source_file" -nt "$cache" ]; then
        rm -f "$sources"
        return 1
      fi
    done <"$sources"
    rm -f "$sources"
    return 0
  fi
  [ ! "$manifest" -nt "$cache" ]
}

nelix_aot_cache_error() {
  reason=$1
  command=$2
  manifest=$3
  case "$reason" in
    missing)
      echo "nelix: AOT cache is missing for $manifest" >&2
      ;;
    stale)
      echo "nelix: AOT cache is older than $manifest" >&2
      ;;
    *)
      echo "nelix: AOT cache is not usable for $manifest" >&2
      ;;
  esac
  echo "nelix: run 'nelix aot-cache $manifest' before retrying $command" >&2
  echo "nelix: set NELIX_NELISP_AOT=0 to force the slower direct NeLisp path" >&2
  exit 2
}

nelix_aot_locked_error() {
  manifest=$1
  echo "nelix: locked AOT check failed for $manifest" >&2
  echo "nelix: run 'nelix lock $manifest' before retrying apply --locked --dry-run" >&2
  echo "nelix: set NELIX_NELISP_AOT=0 to force the slower direct NeLisp path" >&2
  exit 2
}

nelix_aot_lock_check_error() {
  manifest=$1
  echo "nelix: AOT lock-check failed for $manifest" >&2
  echo "nelix: run 'nelix lock $manifest' before retrying lock-check" >&2
  echo "nelix: set NELIX_NELISP_AOT=0 to force the slower direct NeLisp path" >&2
  exit 2
}

nelix_aot_cache_command_p() {
  if [ "$#" -eq 2 ] && [ "$1" = "aot-cache" ]; then
    return 0
  fi
  if [ "$#" -eq 3 ] && [ "$1" = "--json" ] && [ "$2" = "aot-cache" ]; then
    return 0
  fi
  return 1
}

nelix_nelisp_validate_fast_lane() {
  if [ "$#" -eq 3 ] && [ "$1" = "--json" ] && [ "$2" = "validate" ]; then
    nelix_emacs_batch "$@"
    exit "$?"
  fi
  return 1
}

nelix_transaction_log_root_shell() {
  if [ -n "${XDG_STATE_HOME:-}" ]; then
    printf '%s/nelix/transactions\n' "$XDG_STATE_HOME"
  elif [ -n "${HOME:-}" ]; then
    printf '%s/.local/state/nelix/transactions\n' "$HOME"
  else
    printf '%s/.local/state/nelix/transactions\n' "$(pwd)"
  fi
}

nelix_try_transaction_fast_lane() {
  nelix_nelisp_aot_cache_enabled || return 1
  command -v perl >/dev/null 2>&1 || return 1
  [ "${1:-}" = "--json" ] || return 1
  [ "${2:-}" = "transaction" ] || return 1
  command=${3:-}
  root=$(nelix_transaction_log_root_shell)
  case "$command" in
    list)
      if [ "$#" -eq 3 ]; then
        limit=
      elif [ "$#" -eq 5 ] && [ "$4" = "--limit" ]; then
        limit=$5
      else
        return 1
      fi
      perl - "$root" "$limit" <<'PERL'
use strict;
use warnings;

my ($root, $limit) = @ARGV;
$limit = "" unless defined $limit;
if ($limit ne "" && $limit !~ /\A[0-9]+\z/) {
  print STDERR "nelix transaction list: --limit requires a non-negative integer\n";
  exit 2;
}

sub js {
  my ($s) = @_;
  $s = "" unless defined $s;
  $s =~ s/\\/\\\\/g;
  $s =~ s/"/\\"/g;
  $s =~ s/\r/\\r/g;
  $s =~ s/\n/\\n/g;
  $s =~ s/\t/\\t/g;
  return '"' . $s . '"';
}

sub read_record_text {
  my ($file) = @_;
  open my $fh, '<', $file or die "read $file: $!";
  local $/;
  my $text = <$fh>;
  close $fh;
  $text =~ s/\A(?:[^\n]*\n)*?\s*(?=\()//s;
  return $text;
}

sub skip_ws {
  my ($text, $pos) = @_;
  my $len = length($$text);
  while ($$pos < $len) {
    my $ch = substr($$text, $$pos, 1);
    if ($ch =~ /\s/) { $$pos++; next; }
    if ($ch eq ';') {
      $$pos++ while $$pos < $len && substr($$text, $$pos, 1) ne "\n";
      next;
    }
    last;
  }
}

sub parse_expr;
sub parse_string {
  my ($text, $pos) = @_;
  $$pos++;
  my $out = "";
  my $len = length($$text);
  while ($$pos < $len) {
    my $ch = substr($$text, $$pos, 1);
    $$pos++;
    last if $ch eq '"';
    if ($ch eq '\\' && $$pos < $len) {
      my $esc = substr($$text, $$pos, 1);
      $$pos++;
      $out .= $esc eq 'n' ? "\n" : $esc eq 'r' ? "\r" : $esc eq 't' ? "\t" : $esc;
    } else {
      $out .= $ch;
    }
  }
  return ['str', $out];
}

sub parse_atom {
  my ($text, $pos) = @_;
  my $start = $$pos;
  my $len = length($$text);
  $$pos++ while $$pos < $len && substr($$text, $$pos, 1) !~ /[\s()]/;
  return ['sym', substr($$text, $start, $$pos - $start)];
}

sub parse_list {
  my ($text, $pos) = @_;
  $$pos++;
  my @items;
  while (1) {
    skip_ws($text, $pos);
    last if $$pos >= length($$text);
    if (substr($$text, $$pos, 1) eq ')') {
      $$pos++;
      last;
    }
    push @items, parse_expr($text, $pos);
  }
  return \@items;
}

sub parse_expr {
  my ($text, $pos) = @_;
  skip_ws($text, $pos);
  my $ch = substr($$text, $$pos, 1);
  return parse_list($text, $pos) if $ch eq '(';
  return parse_string($text, $pos) if $ch eq '"';
  return parse_atom($text, $pos);
}

sub parse_record {
  my ($file) = @_;
  my $text = read_record_text($file);
  my $pos = 0;
  return parse_expr(\$text, \$pos);
}

sub sym {
  my ($node) = @_;
  return undef unless ref($node) eq 'ARRAY' && @$node == 2 && $node->[0] eq 'sym';
  return $node->[1];
}

sub str_value {
  my ($node) = @_;
  return undef unless ref($node) eq 'ARRAY';
  return $node->[1] if @$node == 2 && ($node->[0] eq 'str' || $node->[0] eq 'sym');
  return undef;
}

sub plist_get {
  my ($node, $key) = @_;
  return undef unless ref($node) eq 'ARRAY';
  for (my $i = 0; $i + 1 < @$node; $i += 2) {
    my $k = sym($node->[$i]);
    return $node->[$i + 1] if defined $k && $k eq $key;
  }
  return undef;
}

sub list_len {
  my ($node) = @_;
  return 0 unless ref($node) eq 'ARRAY';
  return 0 if @$node == 2 && ($node->[0] eq 'sym' || $node->[0] eq 'str');
  return scalar @$node;
}

sub bool_json {
  my ($node) = @_;
  my $s = sym($node);
  return "true" if defined $s && $s eq "t";
  return "false";
}

my @files;
if (-d $root) {
  opendir my $dh, $root or die "open $root: $!";
  @files = map { "$root/$_" } grep { /\Aapply-.*\.el\z/ } readdir($dh);
  closedir $dh;
  @files = sort { (stat($b))[9] <=> (stat($a))[9] } @files;
}
@files = @files[0 .. $limit - 1] if $limit ne "" && @files > $limit;

my @rows;
for my $file (@files) {
  my $record = eval { parse_record($file) };
  next if $@ || !defined $record;
  my $plan = plist_get($record, ':plan');
  my $rollback = plist_get($record, ':rollback-plan');
  my $error = plist_get($record, ':error');
  my $mtime = (stat($file))[9] || 0;
  push @rows, '{'
    . '"id":' . js(str_value(plist_get($record, ':id')) || ($file =~ s!.*/!!r =~ s/\.el\z//r))
    . ',"file":' . js($file)
    . ',"schema":' . js(str_value(plist_get($record, ':schema')) || '')
    . ',"schema-version":' . (str_value(plist_get($record, ':schema-version')) || 0)
    . ',"status":' . js(str_value(plist_get($record, ':status')) || '')
    . ',"manifest":' . js(str_value(plist_get($record, ':manifest')) || '')
    . ',"profile":' . js(str_value(plist_get($record, ':profile')) || '')
    . ',"started-at":' . js(str_value(plist_get($record, ':started-at')) || '')
    . ',"updated-at":' . js(str_value(plist_get($record, ':updated-at')) || '')
    . ',"mtime":' . $mtime
    . ',"command-count":' . list_len(plist_get($plan, ':commands'))
    . ',"executed-count":' . list_len(plist_get($record, ':executed'))
    . ',"rollback-available":' . bool_json(plist_get($rollback, ':available'))
    . (defined sym($error) && sym($error) eq 'nil' ? ',"error":null' : defined str_value($error) ? ',"error":' . js(str_value($error)) : ',"error":null')
    . '}';
}

print '{"status":"ok","operation":"transaction-list","root":' . js($root)
  . ',"count":' . scalar(@rows)
  . ',"transactions":[' . join(',', @rows) . "]}\n";
PERL
      return $?
      ;;
    show)
      [ "$#" -eq 4 ] || return 1
      perl - "$root" "$4" show <<'PERL'
use strict;
use warnings;
my ($root, $id, $mode) = @ARGV;

sub js {
  my ($s) = @_;
  $s = "" unless defined $s;
  $s =~ s/\\/\\\\/g; $s =~ s/"/\\"/g; $s =~ s/\r/\\r/g; $s =~ s/\n/\\n/g; $s =~ s/\t/\\t/g;
  return '"' . $s . '"';
}
sub resolve_file {
  my ($root, $id) = @_;
  return $id if $id =~ m!\A/! || $id =~ m!/!;
  return "$root/$id" if $id =~ /\.el\z/;
  return "$root/$id.el";
}
sub read_record_text {
  my ($file) = @_;
  open my $fh, '<', $file or die "nelix transaction show: record not found: $id\n";
  local $/; my $text = <$fh>; close $fh;
  $text =~ s/\A(?:[^\n]*\n)*?\s*(?=\()//s;
  return $text;
}
sub skip_ws {
  my ($text, $pos) = @_;
  my $len = length($$text);
  while ($$pos < $len) {
    my $ch = substr($$text, $$pos, 1);
    if ($ch =~ /\s/) { $$pos++; next; }
    if ($ch eq ';') { $$pos++ while $$pos < $len && substr($$text, $$pos, 1) ne "\n"; next; }
    last;
  }
}
sub parse_expr;
sub parse_string {
  my ($text, $pos) = @_;
  $$pos++; my $out = ""; my $len = length($$text);
  while ($$pos < $len) {
    my $ch = substr($$text, $$pos, 1); $$pos++; last if $ch eq '"';
    if ($ch eq '\\' && $$pos < $len) {
      my $esc = substr($$text, $$pos, 1); $$pos++;
      $out .= $esc eq 'n' ? "\n" : $esc eq 'r' ? "\r" : $esc eq 't' ? "\t" : $esc;
    } else { $out .= $ch; }
  }
  return ['str', $out];
}
sub parse_atom {
  my ($text, $pos) = @_;
  my $start = $$pos; my $len = length($$text);
  $$pos++ while $$pos < $len && substr($$text, $$pos, 1) !~ /[\s()]/;
  return ['sym', substr($$text, $start, $$pos - $start)];
}
sub parse_list {
  my ($text, $pos) = @_;
  $$pos++; my @items;
  while (1) {
    skip_ws($text, $pos); last if $$pos >= length($$text);
    if (substr($$text, $$pos, 1) eq ')') { $$pos++; last; }
    push @items, parse_expr($text, $pos);
  }
  return \@items;
}
sub parse_expr {
  my ($text, $pos) = @_;
  skip_ws($text, $pos);
  my $ch = substr($$text, $$pos, 1);
  return parse_list($text, $pos) if $ch eq '(';
  return parse_string($text, $pos) if $ch eq '"';
  return parse_atom($text, $pos);
}
sub parse_record {
  my ($file) = @_;
  my $text = read_record_text($file); my $pos = 0;
  return parse_expr(\$text, \$pos);
}
sub sym {
  my ($node) = @_;
  return undef unless ref($node) eq 'ARRAY' && @$node == 2 && $node->[0] eq 'sym';
  return $node->[1];
}
sub sval {
  my ($node) = @_;
  return undef unless ref($node) eq 'ARRAY' && @$node == 2 && ($node->[0] eq 'str' || $node->[0] eq 'sym');
  return $node->[1];
}
sub plist_p {
  my ($node) = @_;
  return 0 unless ref($node) eq 'ARRAY' && @$node % 2 == 0;
  for (my $i = 0; $i < @$node; $i += 2) {
    my $k = sym($node->[$i]);
    return 0 unless defined $k && $k =~ /^:/;
  }
  return 1;
}
sub key_name {
  my ($node) = @_;
  my $k = sym($node); $k = "" unless defined $k; $k =~ s/^://;
  return $k;
}
sub enc {
  my ($node) = @_;
  return 'null' unless defined $node;
  if (ref($node) eq 'ARRAY' && @$node == 2 && $node->[0] eq 'str') { return js($node->[1]); }
  if (ref($node) eq 'ARRAY' && @$node == 2 && $node->[0] eq 'sym') {
    my $s = $node->[1];
    return 'true' if $s eq 't';
    return 'null' if $s eq 'nil';
    return $s if $s =~ /\A-?[0-9]+(?:\.[0-9]+)?\z/;
    return js($s);
  }
  if (plist_p($node)) {
    my @fields;
    for (my $i = 0; $i + 1 < @$node; $i += 2) {
      push @fields, js(key_name($node->[$i])) . ':' . enc($node->[$i + 1]);
    }
    return '{' . join(',', @fields) . '}';
  }
  return '[' . join(',', map { enc($_) } @$node) . ']';
}
sub plist_get {
  my ($node, $key) = @_;
  return undef unless ref($node) eq 'ARRAY';
  for (my $i = 0; $i + 1 < @$node; $i += 2) {
    my $k = sym($node->[$i]);
    return $node->[$i + 1] if defined $k && $k eq $key;
  }
  return undef;
}
sub list_len {
  my ($node) = @_;
  return 0 unless ref($node) eq 'ARRAY';
  return 0 if @$node == 2 && ($node->[0] eq 'sym' || $node->[0] eq 'str');
  return scalar @$node;
}
my $file = resolve_file($root, $id);
my $record = parse_record($file);
if ($mode eq 'show') {
  print '{"status":"ok","operation":"transaction-show","file":' . js($file) . ',"record":' . enc($record) . "}\n";
  exit 0;
}
my $rollback = plist_get($record, ':rollback-plan');
my $available = sym(plist_get($rollback, ':available'));
if (!defined($available) || $available ne 't') {
  my $reason = sval(plist_get($rollback, ':reason')) || 'unknown';
  print STDERR "nelix transaction recover: rollback unavailable for $id: $reason\n";
  exit 2;
}
my $transaction = plist_get($record, ':transaction');
my $backend = sval(plist_get($transaction, ':backend')) || '';
my $profile = sval(plist_get($transaction, ':profile'));
my $generation = sval(plist_get($rollback, ':generation'));
my @manual = $backend eq 'nelix-native' ? ('native', 'rollback') : ('rollback');
push @manual, '--profile', $profile if defined($profile) && $profile ne '' && $profile ne 'nil' && $backend eq 'nelix-native';
push @manual, '--generation', $generation if $backend eq 'nelix-native' && defined($generation) && $generation ne '';
@manual = ('rollback', $generation) if $backend ne 'nelix-native' && defined($generation) && $generation ne '';
my $plan = plist_get($record, ':plan');
print '{"status":"ok","operation":"transaction-recover","dry-run":true'
  . ',"file":' . js($file)
  . ',"record-id":' . js(sval(plist_get($record, ':id')) || '')
  . ',"record-status":' . js(sval(plist_get($record, ':status')) || '')
  . ',"backend":' . js($backend)
  . ',"profile":' . (defined($profile) && $profile ne 'nil' ? js($profile) : 'null')
  . ',"generation":' . (defined($generation) && $generation =~ /\A[0-9]+\z/ ? $generation : 'null')
  . ',"rollback-plan":' . enc($rollback)
  . ',"manual-command":[' . join(',', map { js($_) } @manual) . ']'
  . ',"command-count":' . list_len(plist_get($plan, ':commands'))
  . ',"executed-count":' . list_len(plist_get($record, ':executed'))
  . "}\n";
PERL
      return $?
      ;;
    recover)
      [ "$#" -eq 5 ] && [ "$5" = "--dry-run" ] || return 1
      perl - "$root" "$4" recover <<'PERL'
use strict;
use warnings;
my ($root, $id, $mode) = @ARGV;

sub js {
  my ($s) = @_;
  $s = "" unless defined $s;
  $s =~ s/\\/\\\\/g; $s =~ s/"/\\"/g; $s =~ s/\r/\\r/g; $s =~ s/\n/\\n/g; $s =~ s/\t/\\t/g;
  return '"' . $s . '"';
}
sub resolve_file {
  my ($root, $id) = @_;
  return $id if $id =~ m!\A/! || $id =~ m!/!;
  return "$root/$id" if $id =~ /\.el\z/;
  return "$root/$id.el";
}
sub read_record_text {
  my ($file) = @_;
  open my $fh, '<', $file or die "nelix transaction show: record not found: $id\n";
  local $/; my $text = <$fh>; close $fh;
  $text =~ s/\A(?:[^\n]*\n)*?\s*(?=\()//s;
  return $text;
}
sub skip_ws {
  my ($text, $pos) = @_;
  my $len = length($$text);
  while ($$pos < $len) {
    my $ch = substr($$text, $$pos, 1);
    if ($ch =~ /\s/) { $$pos++; next; }
    if ($ch eq ';') { $$pos++ while $$pos < $len && substr($$text, $$pos, 1) ne "\n"; next; }
    last;
  }
}
sub parse_expr;
sub parse_string {
  my ($text, $pos) = @_;
  $$pos++; my $out = ""; my $len = length($$text);
  while ($$pos < $len) {
    my $ch = substr($$text, $$pos, 1); $$pos++; last if $ch eq '"';
    if ($ch eq '\\' && $$pos < $len) {
      my $esc = substr($$text, $$pos, 1); $$pos++;
      $out .= $esc eq 'n' ? "\n" : $esc eq 'r' ? "\r" : $esc eq 't' ? "\t" : $esc;
    } else { $out .= $ch; }
  }
  return ['str', $out];
}
sub parse_atom {
  my ($text, $pos) = @_;
  my $start = $$pos; my $len = length($$text);
  $$pos++ while $$pos < $len && substr($$text, $$pos, 1) !~ /[\s()]/;
  return ['sym', substr($$text, $start, $$pos - $start)];
}
sub parse_list {
  my ($text, $pos) = @_;
  $$pos++; my @items;
  while (1) {
    skip_ws($text, $pos); last if $$pos >= length($$text);
    if (substr($$text, $$pos, 1) eq ')') { $$pos++; last; }
    push @items, parse_expr($text, $pos);
  }
  return \@items;
}
sub parse_expr {
  my ($text, $pos) = @_;
  skip_ws($text, $pos);
  my $ch = substr($$text, $$pos, 1);
  return parse_list($text, $pos) if $ch eq '(';
  return parse_string($text, $pos) if $ch eq '"';
  return parse_atom($text, $pos);
}
sub parse_record {
  my ($file) = @_;
  my $text = read_record_text($file); my $pos = 0;
  return parse_expr(\$text, \$pos);
}
sub sym {
  my ($node) = @_;
  return undef unless ref($node) eq 'ARRAY' && @$node == 2 && $node->[0] eq 'sym';
  return $node->[1];
}
sub sval {
  my ($node) = @_;
  return undef unless ref($node) eq 'ARRAY' && @$node == 2 && ($node->[0] eq 'str' || $node->[0] eq 'sym');
  return $node->[1];
}
sub plist_p {
  my ($node) = @_;
  return 0 unless ref($node) eq 'ARRAY' && @$node % 2 == 0;
  for (my $i = 0; $i < @$node; $i += 2) {
    my $k = sym($node->[$i]);
    return 0 unless defined $k && $k =~ /^:/;
  }
  return 1;
}
sub key_name {
  my ($node) = @_;
  my $k = sym($node); $k = "" unless defined $k; $k =~ s/^://;
  return $k;
}
sub enc {
  my ($node) = @_;
  return 'null' unless defined $node;
  if (ref($node) eq 'ARRAY' && @$node == 2 && $node->[0] eq 'str') { return js($node->[1]); }
  if (ref($node) eq 'ARRAY' && @$node == 2 && $node->[0] eq 'sym') {
    my $s = $node->[1];
    return 'true' if $s eq 't';
    return 'null' if $s eq 'nil';
    return $s if $s =~ /\A-?[0-9]+(?:\.[0-9]+)?\z/;
    return js($s);
  }
  if (plist_p($node)) {
    my @fields;
    for (my $i = 0; $i + 1 < @$node; $i += 2) {
      push @fields, js(key_name($node->[$i])) . ':' . enc($node->[$i + 1]);
    }
    return '{' . join(',', @fields) . '}';
  }
  return '[' . join(',', map { enc($_) } @$node) . ']';
}
sub plist_get {
  my ($node, $key) = @_;
  return undef unless ref($node) eq 'ARRAY';
  for (my $i = 0; $i + 1 < @$node; $i += 2) {
    my $k = sym($node->[$i]);
    return $node->[$i + 1] if defined $k && $k eq $key;
  }
  return undef;
}
sub list_len {
  my ($node) = @_;
  return 0 unless ref($node) eq 'ARRAY';
  return 0 if @$node == 2 && ($node->[0] eq 'sym' || $node->[0] eq 'str');
  return scalar @$node;
}
my $file = resolve_file($root, $id);
my $record = parse_record($file);
my $rollback = plist_get($record, ':rollback-plan');
my $available = sym(plist_get($rollback, ':available'));
if (!defined($available) || $available ne 't') {
  my $reason = sval(plist_get($rollback, ':reason')) || 'unknown';
  print STDERR "nelix transaction recover: rollback unavailable for $id: $reason\n";
  exit 2;
}
my $transaction = plist_get($record, ':transaction');
my $backend = sval(plist_get($transaction, ':backend')) || '';
my $profile = sval(plist_get($transaction, ':profile'));
my $generation = sval(plist_get($rollback, ':generation'));
my @manual = $backend eq 'nelix-native' ? ('native', 'rollback') : ('rollback');
push @manual, '--profile', $profile if defined($profile) && $profile ne '' && $profile ne 'nil' && $backend eq 'nelix-native';
push @manual, '--generation', $generation if $backend eq 'nelix-native' && defined($generation) && $generation ne '';
@manual = ('rollback', $generation) if $backend ne 'nelix-native' && defined($generation) && $generation ne '';
my $plan = plist_get($record, ':plan');
print '{"status":"ok","operation":"transaction-recover","dry-run":true'
  . ',"file":' . js($file)
  . ',"record-id":' . js(sval(plist_get($record, ':id')) || '')
  . ',"record-status":' . js(sval(plist_get($record, ':status')) || '')
  . ',"backend":' . js($backend)
  . ',"profile":' . (defined($profile) && $profile ne 'nil' ? js($profile) : 'null')
  . ',"generation":' . (defined($generation) && $generation =~ /\A[0-9]+\z/ ? $generation : 'null')
  . ',"rollback-plan":' . enc($rollback)
  . ',"manual-command":[' . join(',', map { js($_) } @manual) . ']'
  . ',"command-count":' . list_len(plist_get($plan, ':commands'))
  . ',"executed-count":' . list_len(plist_get($record, ':executed'))
  . "}\n";
PERL
      return $?
      ;;
    *)
      return 1
      ;;
  esac
}

nelix_emacs_batch() {
  "${EMACS:-emacs}" -Q --batch \
    -L "$lispdir" \
    -L "$lispdir/scripts" \
    -l "$clifile" \
    --eval '(nelix-cli-main command-line-args-left)' \
    -- "$@"
}

nelix_run_emacs_batch() {
  exec "${EMACS:-emacs}" -Q --batch \
    -L "$lispdir" \
    -L "$lispdir/scripts" \
    -l "$clifile" \
    --eval '(nelix-cli-main command-line-args-left)' \
    -- "$@"
}

nelix_build_aot_cache() {
  manifest=$1
  cache_stdout=$(mktemp "${TMPDIR:-/tmp}/nelix-aot-cache-stdout.XXXXXX")
  cache_stderr=$(mktemp "${TMPDIR:-/tmp}/nelix-aot-cache-stderr.XXXXXX")
  set +e
  nelix_emacs_batch aot-cache "$manifest" >"$cache_stdout" 2>"$cache_stderr"
  status=$?
  set -e
  if [ "$status" -ne 0 ]; then
    cat "$cache_stderr" >&2
    cat "$cache_stdout" >&2
    rm -f "$cache_stdout" "$cache_stderr"
    return "$status"
  fi
  rm -f "$cache_stdout" "$cache_stderr"
  return 0
}

nelix_emit_aot_cache_runtime_prefix() {
  cache=$1
  if awk -F '\t' '$1 == "target-id" { found = 1 } END { exit(found ? 0 : 1) }' "$cache"; then
    awk -F '\t' '
      NR == 1 ||
      $1 == "manifest" ||
      $1 == "source-file" ||
      $1 == "profile" ||
      $1 == "system" ||
      $1 == "name-id" ||
      $1 == "target-id" ||
      $1 == "pin-id" {
        print
      }
    ' "$cache"
  else
    cat "$cache"
  fi
}

nelix_aot_lock_manifest_files_current_p() {
  lock=$1
  rows=$(mktemp "${TMPDIR:-/tmp}/nelix-lock-files.XXXXXX")
  awk '
    {
      line = $0
      while (match(line, /:path "[^"]+" :digest "sha256-[0-9a-f]+"/)) {
        row = substr(line, RSTART, RLENGTH)
        sub(/^:path "/, "", row)
        sub(/" :digest "/, "\t", row)
        sub(/"$/, "", row)
        print row
        line = substr(line, RSTART + RLENGTH)
      }
    }
  ' "$lock" >"$rows"
  [ -s "$rows" ] || {
    rm -f "$rows"
    return 1
  }
  while IFS='	' read -r path expected; do
    [ -f "$path" ] || {
      rm -f "$rows"
      return 1
    }
    actual=sha256-$(sha256sum "$path" | awk '{ print $1 }')
    [ "$actual" = "$expected" ] || {
      rm -f "$rows"
      return 1
    }
  done <"$rows"
  rm -f "$rows"
}

nelix_aot_lock_targets_match_cache_p() {
  lock=$1
  cache=$2
  targets=$(mktemp "${TMPDIR:-/tmp}/nelix-lock-targets.XXXXXX")
  awk '
    BEGIN { RS = "\\(:name " }
    function value(row, key,   pat, start, rest, end) {
      pat = ":" key " "
      start = index(row, pat)
      if (!start) return ""
      rest = substr(row, start + length(pat))
      if (substr(rest, 1, 1) == "\"") {
        rest = substr(rest, 2)
        end = index(rest, "\"")
        if (!end) return ""
        return substr(rest, 1, end - 1)
      }
      if (substr(rest, 1, 1) == sprintf("%c", 39)) {
        rest = substr(rest, 2)
      }
      if (match(rest, /^[^ \t\n)]+/)) {
        return substr(rest, RSTART, RLENGTH)
      }
      return ""
    }
    NR > 1 {
      target = value($0, "resolved-target")
      if (target == "" || target == "nil") {
        target = value($0, "target")
      }
      if (target != "" && target != "nil") {
        print target
      }
    }
  ' "$lock" >"$targets"
  [ -s "$targets" ] || {
    rm -f "$targets"
    return 1
  }
  if awk -F '	' '$1 == "target-id" { found = 1 } END { exit(found ? 0 : 1) }' "$cache"; then
    target_record=target-id
  else
    target_record=target
  fi
  awk -F '	' -v record="$target_record" '
    FILENAME == ARGV[1] {
      lock[$1] = 1
      lock_count++
      next
    }
    $1 == "name-id" && $2 != "" && $3 != "" {
      name[$2] = $3
      next
    }
    record == "target" && $1 == "target" {
      target_count++
      ok = 0
      for (i = 3; i <= NF; i++) {
        if ($i in lock) ok = 1
      }
      if (!ok) missing++
      next
    }
    record == "target-id" && $1 == "target-id" {
      target_count++
      ok = 0
      for (i = 3; i <= NF; i++) {
        if (($i in name) && (name[$i] in lock)) ok = 1
      }
      if (!ok) missing++
      next
    }
    END {
      exit((target_count > 0 && missing == 0) ? 0 : 1)
    }
  ' "$targets" "$cache"
  rc=$?
  rm -f "$targets"
  return "$rc"
}

nelix_aot_locked_dry_run_check() {
  manifest=$1
  cache=$2
  lock=${manifest}.nelix-lock
  [ -f "$lock" ] || return 1

  cache_profile=$(awk -F '	' '$1 == "profile" { print $2; exit }' "$cache")
  cache_system=$(awk -F '	' '$1 == "system" { print $2; exit }' "$cache")
  [ -n "$cache_profile" ] || return 1
  [ -n "$cache_system" ] || return 1

  grep -Fq ':schema "nelix-lock"' "$lock" || return 1
  grep -Fq ':schema-version 2' "$lock" || return 1
  grep -Fq ":profile \"$cache_profile\"" "$lock" || return 1
  # Backend is pinned transitively: the manifest digest (which covers the
  # backend-policy form) and the system check below together determine the
  # selected backend.  Accept whatever backend the lock records (nix,
  # nelix-native, apt, ...) instead of hard-coding nix, so AOT lock-check
  # works for the no-Nix native backend too.
  lock_backend=$(
    sed -n "s/.*:backend '\([A-Za-z][A-Za-z0-9-]*\).*/\1/p" "$lock" | head -n 1
  )
  case "$lock_backend" in
    '' | nil) return 1 ;;
  esac
  grep -Fq ":system '$cache_system" "$lock" ||
    grep -Fq ":system $cache_system" "$lock" ||
    return 1

  nelix_aot_lock_manifest_files_current_p "$lock" || return 1
  nelix_aot_lock_targets_match_cache_p "$lock" "$cache" || return 1
}

nelix_run_aot_id_cache_shell_lane() {
  command=$1
  json=$2
  cache=$3
  profile=$4
  nix_program=$5
  locked=0

  awk -F '\t' '$1 == "target-id" { found = 1 } END { exit(found ? 0 : 1) }' "$cache" || return 1

  if [ "$command" = "apply-dry-run-locked" ]; then
    nelix_aot_locked_dry_run_check "$manifest" "$cache" ||
      nelix_aot_locked_error "$manifest"
    command=apply-dry-run
    locked=1
  fi

  if [ "$command" = "lock-check" ]; then
    nelix_aot_locked_dry_run_check "$manifest" "$cache" ||
      nelix_aot_lock_check_error "$manifest"
    cache_profile=$(awk -F '	' '$1 == "profile" { print $2; exit }' "$cache")
    cache_system=$(awk -F '	' '$1 == "system" { print $2; exit }' "$cache")
    cache_backend=$(awk -F '	' '$1 == "backend" { print $2; exit }' "$cache")
    [ -n "$cache_backend" ] || cache_backend=nix
    lock=${manifest}.nelix-lock
    if [ "$json" -eq 1 ]; then
      printf '{"ok":true'
      printf ',"manifest":%s' "$(nelix_quote_elisp_string "$manifest")"
      printf ',"lock":%s' "$(nelix_quote_elisp_string "$lock")"
      printf ',"schema-check":{"ok":true,"schema":"nelix-lock","schema-version":2,"current-schema":"nelix-lock","current-schema-version":2,"version":2}'
      printf ',"checked-by":":nelisp-aot-cache"'
      printf ',"profile":%s' "$(nelix_quote_elisp_string "$cache_profile")"
      printf ',"system":%s' "$(nelix_quote_elisp_string "$cache_system")"
      printf ',"backend":%s,"backend-selection":{"backend":%s,"system":%s,"fallback":":nelisp-aot-cache"}' "$(nelix_quote_elisp_string "$cache_backend")" "$(nelix_quote_elisp_string "$cache_backend")" "$(nelix_quote_elisp_string "$cache_system")"
      printf ',"aot-cache":%s}\n' "$(nelix_quote_elisp_string "$cache")"
    else
      printf 'ok\ttrue\n'
      printf 'manifest\t%s\nlock\t%s\n' "$manifest" "$lock"
      printf 'schema\tnelix-lock\nschema-version\t2\nversion\t2\n'
      printf 'checked-by\t:nelisp-aot-cache\n'
      printf 'profile\t%s\nsystem\t%s\n' "$cache_profile" "$cache_system"
      printf 'backend\t%s\nfallback\t:nelisp-aot-cache\naot-cache\t%s\n' "$cache_backend" "$cache"
    fi
    return 0
  fi

  "$nix_program" profile list --profile "$profile" \
    | sed -n 's/\x1b\[[0-9;]*m//g; s/^Name:[[:space:]]*//p' \
    | awk -F '\t' -v command="$command" -v json="$json" \
        -v locked="$locked" -v cache_file="$cache" \
        -v lock_present="$([ -f "${manifest}.nelix-lock" ] && printf true || printf false)" \
        -v profile_path="$profile" '
        function norm(s, t) {
          t = s
          sub(/-[0-9]+$/, "", t)
          return t
        }
        function j(s, t) {
          t = s
          gsub(/\\/, "\\\\", t)
          gsub(/"/, "\\\"", t)
          gsub(/\r/, "\\r", t)
          gsub(/\t/, "\\t", t)
          return "\"" t "\""
        }
        function bool(v) {
          return v ? "true" : "false"
        }
        function json_names(arr, n,   i) {
          printf "["
          for (i = 1; i <= n; i++) {
            if (i > 1) printf ","
            printf "%s", j(arr[i])
          }
          printf "]"
        }
        function json_action_object(action, name) {
          printf "{\"action\":%s,\"name\":%s,\"backend\":%s", j(action), j(name), j(backend_value)
          if (action == "install") {
            printf ",\"target\":%s,\"resolved-target\":%s", j(name), j(name)
            printf ",\"installed-name\":null,\"argv\":[\"profile\",\"install\",\"--profile\",%s,%s]", j(profile_path), j("nixpkgs#" name)
          } else if (action == "remove") {
            printf ",\"target\":null,\"resolved-target\":null"
            printf ",\"installed-name\":%s,\"argv\":[\"profile\",\"remove\",%s,\"--profile\",%s]", j(name), j(name), j(profile_path)
          }
          printf "}"
        }
        function json_actions(action, arr, n,   i) {
          printf "["
          for (i = 1; i <= n; i++) {
            if (i > 1) printf ","
            json_action_object(action, arr[i])
          }
          printf "]"
        }
        function line_names(key, arr, n,   i) {
          for (i = 1; i <= n; i++) {
            printf "%s\t%s\n", key, arr[i]
          }
        }
        function add_present(value) {
          if (!(value in seen_present)) {
            seen_present[value] = 1
            present[++present_count] = value
          }
        }
        function add_keep(value) {
          if (!(value in seen_keep)) {
            seen_keep[value] = 1
            keep[++keep_count] = value
          }
        }
        function add_pinned(value) {
          if (!(value in seen_pinned)) {
            seen_pinned[value] = 1
            pinned[++pinned_count] = value
          }
        }
        function add_upgrade(value) {
          if (!(value in seen_upgrade)) {
            seen_upgrade[value] = 1
            upgrade[++upgrade_count] = value
          }
        }
        function add_missing(value) {
          if (!(value in seen_missing)) {
            seen_missing[value] = 1
            missing[++missing_count] = value
          }
        }
        function string_find_target(t,   i, name, lookup) {
          for (i = 1; i <= string_target_candidate_count[t]; i++) {
            name = string_target_candidate[t, i]
            if (name in installed_by_name) {
              return installed_by_name[name]
            }
          }
          for (i = 1; i <= string_target_candidate_count[t]; i++) {
            lookup = norm(string_target_candidate[t, i])
            if (lookup in installed_by_norm) {
              return installed_by_norm[lookup]
            }
          }
          return ""
        }
        FILENAME == ARGV[1] {
          if ($1 == "manifest") {
            manifest = $2
          } else if ($1 == "profile") {
            profile_name = $2
          } else if ($1 == "system") {
            system_value = $2
          } else if ($1 == "backend") {
            backend_value = $2
          } else if ($1 == "target" && $2 != "") {
            string_target_count++
            string_target_display[string_target_count] = $2
            string_target_candidate_count[string_target_count] = NF - 2
            for (i = 3; i <= NF; i++) {
              string_target_candidate[string_target_count, i - 2] = $i
              desired_string[$i] = 1
              desired_string[norm($i)] = 1
            }
          } else if ($1 == "pin" && $2 != "") {
            string_pin_order[++string_pin_count] = $2
            pin_name[$2] = 1
            pin_name[norm($2)] = 1
          } else if ($1 == "name-id" && $2 != "" && $3 != "") {
            name_by_id[$2] = $3
            id_by_name[$3] = $2
            id_by_name[norm($3)] = $2
          } else if ($1 == "target-id" && $2 != "") {
            target_count++
            target_display[target_count] = $2
            target_candidate_count[target_count] = NF - 2
            for (i = 3; i <= NF; i++) {
              target_candidate[target_count, i - 2] = $i
              desired_id[$i] = 1
            }
          } else if ($1 == "pin-id" && $2 != "") {
            pin_id[$2] = 1
            pin_order[++pin_count] = $2
          }
          next
        }
        {
          raw = $0
          installed[++installed_count] = raw
          installed_by_name[raw] = raw
          installed_by_norm[norm(raw)] = raw
          lookup = norm(raw)
          id = ""
          if (raw in id_by_name) {
            id = id_by_name[raw]
          } else if (lookup in id_by_name) {
            id = id_by_name[lookup]
          }
          installed_id_by_row[installed_count] = id
          if (id != "") {
            installed_id[id] = 1
            if (!(id in installed_name_by_id)) {
              installed_name_by_id[id] = raw
            }
          }
        }
        END {
          if (string_target_count > 0) {
            for (t = 1; t <= string_target_count; t++) {
              found_name = string_find_target(t)
              if (found_name == "") {
                add_missing(string_target_display[t])
              } else if (command == "audit") {
                add_present(found_name)
              } else if (command == "plan" || command == "apply-dry-run") {
                add_keep(string_target_display[t])
              } else if (found_name in pin_name || norm(found_name) in pin_name) {
                add_pinned(found_name)
              } else {
                add_upgrade(found_name)
              }
            }

            for (i = 1; i <= string_pin_count; i++) {
              pinned_names[++pinned_names_count] = string_pin_order[i]
            }
          } else {
            for (id in desired_id) {
              desired_name[name_by_id[id]] = 1
              desired_name[norm(name_by_id[id])] = 1
            }

            for (t = 1; t <= target_count; t++) {
              found_id = ""
              for (i = 1; i <= target_candidate_count[t]; i++) {
                id = target_candidate[t, i]
                if (id in installed_id) {
                  found_id = id
                  break
                }
              }
              if (found_id == "") {
                add_missing(name_by_id[target_display[t]])
              } else if (command == "audit") {
                add_present(installed_name_by_id[found_id])
              } else if (command == "plan" || command == "apply-dry-run") {
                add_keep(name_by_id[target_display[t]])
              } else if (found_id in pin_id) {
                add_pinned(installed_name_by_id[found_id])
              } else {
                add_upgrade(installed_name_by_id[found_id])
              }
            }

            for (i = 1; i <= pin_count; i++) {
              pinned_names[++pinned_names_count] = name_by_id[pin_order[i]]
              pin_name[name_by_id[pin_order[i]]] = 1
              pin_name[norm(name_by_id[pin_order[i]])] = 1
            }
          }

          if (command == "audit" || command == "plan" || command == "apply-dry-run") {
            for (i = 1; i <= installed_count; i++) {
              raw = installed[i]
              id = installed_id_by_row[i]
              if (string_target_count > 0) {
                if (!(raw in desired_string) && !(norm(raw) in desired_string)) {
                  if ((command == "plan" || command == "apply-dry-run") && (raw in pin_name || norm(raw) in pin_name)) {
                    protected[++protected_count] = raw
                  } else {
                    extra[++extra_count] = raw
                  }
                }
              } else if (id != "") {
                if (!(id in desired_id)) {
                  if ((command == "plan" || command == "apply-dry-run") && (id in pin_id || raw in pin_name || norm(raw) in pin_name)) {
                    protected[++protected_count] = raw
                  } else {
                    extra[++extra_count] = raw
                  }
                }
              } else if (!(raw in desired_name) && !(norm(raw) in desired_name)) {
                if ((command == "plan" || command == "apply-dry-run") && (raw in pin_name || norm(raw) in pin_name)) {
                  protected[++protected_count] = raw
                } else {
                  extra[++extra_count] = raw
                }
              }
            }
          }

          apply_status = "planned"
          if (command == "apply-dry-run") {
            apply_status = "dry-run"
          }
          if (backend_value == "") backend_value = "nix"

          if (json == "1") {
            if (command == "audit") {
              printf "{\"ok\":%s", bool(missing_count == 0 && extra_count == 0)
              printf ",\"manifest\":%s", j(manifest)
              printf ",\"profile\":%s", j(profile_name)
              printf ",\"system\":%s", j(system_value)
              printf ",\"present\":"; json_names(present, present_count)
              printf ",\"missing\":"; json_names(missing, missing_count)
              printf ",\"extra\":"; json_names(extra, extra_count)
              printf ",\"skipped\":{\"state-pins\":\"nelisp-aot\",\"lock-drift\":\"nelisp-aot\",\"linux-command-audit\":\"nelisp-aot\"}"
              printf ",\"backend\":%s,\"backend-selection\":{\"backend\":%s,\"system\":%s,\"fallback\":\":nelisp-aot-cache\"}", j(backend_value), j(backend_value), j(system_value)
              printf ",\"aot-cache\":%s}\n", j(cache_file)
            } else if (command == "plan" || command == "apply-dry-run") {
              printf "{\"operation\":\"apply\",\"status\":%s,\"dry-run\":true", j(apply_status)
              printf ",\"manifest\":%s", j(manifest)
              printf ",\"lock\":%s", j(manifest ".nelix-lock")
              printf ",\"lock-present\":%s", lock_present
              printf ",\"profile\":%s", j(profile_name)
              printf ",\"nix-profile\":%s", j(profile_path)
              printf ",\"system\":%s", j(system_value)
              printf ",\"install\":"; json_actions("install", missing, missing_count)
              printf ",\"remove\":"; json_actions("remove", extra, extra_count)
              printf ",\"keep\":"; json_actions("keep", keep, keep_count)
              printf ",\"protected\":"; json_actions("protect", protected, protected_count)
              printf ",\"commands\":["
              for (i = 1; i <= missing_count; i++) {
                if (i > 1) printf ","
                json_action_object("install", missing[i])
              }
              for (i = 1; i <= extra_count; i++) {
                if (missing_count > 0 || i > 1) printf ","
                json_action_object("remove", extra[i])
              }
              printf "]"
              printf ",\"count\":%d", missing_count + extra_count
              printf ",\"empty\":%s", bool(missing_count == 0 && extra_count == 0)
              printf ",\"remove-safety\":{\"remove-count\":%d,\"allow-remove\":false,\"allow-remove-count\":null,\"allowed\":%s,\"required\":%s}", extra_count, bool(extra_count == 0), bool(extra_count > 0)
              printf ",\"lock-drift\":null"
              printf ",\"skipped\":{\"lock-drift\":\"nelisp-aot\",\"lock-read\":\"nelisp-aot\",\"transaction\":\"nelisp-aot\"}"
              if (locked == "1") {
                printf ",\"locked\":true,\"lock-enforced\":true"
                printf ",\"lock-check\":{\"ok\":true,\"checked-by\":\":nelisp-aot-cache\"}"
                printf ",\"locked-installed\":"; json_actions("install", missing, missing_count)
              }
              printf ",\"backend\":%s,\"backend-selection\":{\"backend\":%s,\"system\":%s,\"fallback\":\":nelisp-aot-cache\"}", j(backend_value), j(backend_value), j(system_value)
              printf ",\"aot-cache\":%s}\n", j(cache_file)
            } else {
              printf "{\"operation\":\"upgrade\",\"name\":\":manifest\""
              printf ",\"count\":%d", upgrade_count
              printf ",\"upgrade\":"; json_names(upgrade, upgrade_count)
              printf ",\"pinned\":"; json_names(pinned, pinned_count)
              printf ",\"pinned-names\":"; json_names(pinned_names, pinned_names_count)
              printf ",\"blocked\":null,\"empty\":%s", bool(upgrade_count == 0)
              printf ",\"manifest\":%s", j(manifest)
              printf ",\"profile\":%s", j(profile_name)
              printf ",\"system\":%s", j(system_value)
              printf ",\"missing\":"; json_names(missing, missing_count)
              printf ",\"extra\":null,\"lock-drift\":null"
              printf ",\"skipped\":{\"extra-scan\":\"nelisp-aot\",\"lock-drift\":\"nelisp-aot\",\"state-pins\":\"nelisp-aot\"}"
              printf ",\"backend\":%s,\"backend-selection\":{\"backend\":%s,\"system\":%s,\"fallback\":\":nelisp-aot-cache\"}", j(backend_value), j(backend_value), j(system_value)
              printf ",\"aot-cache\":%s}\n", j(cache_file)
            }
          } else if (command == "audit") {
            printf "ok\t%s\n", bool(missing_count == 0 && extra_count == 0)
            printf "manifest\t%s\nprofile\t%s\nsystem\t%s\n", manifest, profile_name, system_value
            line_names("present", present, present_count)
            line_names("missing", missing, missing_count)
            line_names("extra", extra, extra_count)
            printf "backend\t%s\nfallback\t:nelisp-aot-cache\naot-cache\t%s\n", backend_value, cache_file
          } else if (command == "plan" || command == "apply-dry-run") {
            printf "operation\tapply\nstatus\t%s\ndry-run\ttrue\n", apply_status
            printf "manifest\t%s\nlock\t%s.nelix-lock\nlock-present\t%s\n", manifest, manifest, lock_present
            printf "profile\t%s\nnix-profile\t%s\nsystem\t%s\n", profile_name, profile_path, system_value
            line_names("install", missing, missing_count)
            line_names("remove", extra, extra_count)
            line_names("keep", keep, keep_count)
            line_names("protected", protected, protected_count)
            printf "count\t%d\nempty\t%s\n", missing_count + extra_count, bool(missing_count == 0 && extra_count == 0)
            printf "remove-count\t%d\nremove-required\t%s\n", extra_count, bool(extra_count > 0)
            if (locked == "1") {
              printf "locked\ttrue\nlock-enforced\ttrue\nlock-check\tok\n"
            }
            printf "backend\t%s\nfallback\t:nelisp-aot-cache\naot-cache\t%s\n", backend_value, cache_file
          } else {
            printf "operation\tupgrade\nname\t:manifest\ncount\t%d\nempty\t%s\n", upgrade_count, bool(upgrade_count == 0)
            printf "manifest\t%s\nprofile\t%s\nsystem\t%s\n", manifest, profile_name, system_value
            line_names("upgrade", upgrade, upgrade_count)
            line_names("pinned", pinned, pinned_count)
            line_names("pinned-name", pinned_names, pinned_names_count)
            line_names("missing", missing, missing_count)
            printf "backend\t%s\nfallback\t:nelisp-aot-cache\naot-cache\t%s\n", backend_value, cache_file
          }
        }
      ' "$cache" -
}

nelix_run_aot_apply_shell_lane() {
  command=$1
  json=$2
  cache=$3
  profile=$4
  nix_program=$5
  allow_remove_count=$6
  locked=0

  [ "$json" -eq 1 ] || return 1
  command -v perl >/dev/null 2>&1 || return 1

  case "$command" in
    apply-real)
      ;;
    apply-real-locked)
      nelix_aot_locked_dry_run_check "$manifest" "$cache" ||
        nelix_aot_locked_error "$manifest"
      locked=1
      ;;
    *)
      return 1
      ;;
  esac

  perl - "$manifest" "$cache" "$profile" "$nix_program" "$allow_remove_count" "$locked" "$(nelix_transaction_log_root_shell)" <<'PERL'
use strict;
use warnings;
use POSIX qw(strftime);

my ($manifest, $cache, $profile, $nix, $allow_remove_count, $locked, $txn_root) = @ARGV;
$allow_remove_count = "" unless defined $allow_remove_count;

sub js {
  my ($s) = @_;
  $s = "" unless defined $s;
  $s =~ s/\\/\\\\/g; $s =~ s/"/\\"/g; $s =~ s/\r/\\r/g; $s =~ s/\n/\\n/g; $s =~ s/\t/\\t/g;
  return '"' . $s . '"';
}

sub sx {
  my ($s) = @_;
  $s = "" unless defined $s;
  $s =~ s/\\/\\\\/g; $s =~ s/"/\\"/g; $s =~ s/\r/\\r/g; $s =~ s/\n/\\n/g; $s =~ s/\t/\\t/g;
  return '"' . $s . '"';
}

sub sym_or_nil {
  my ($s) = @_;
  return "nil" unless defined $s && $s ne "";
  return $s;
}

sub run_capture {
  my (@cmd) = @_;
  open my $fh, '-|', @cmd or die "run @cmd: $!";
  local $/;
  my $out = <$fh>;
  close $fh;
  my $rc = $? >> 8;
  return ($rc, defined($out) ? $out : "");
}

sub run_status {
  my (@cmd) = @_;
  system @cmd;
  return $? >> 8;
}

sub profile_names {
  my ($rc, $out) = run_capture($nix, 'profile', 'list', '--profile', $profile);
  exit 2 if $rc != 0;
  my @names;
  for my $line (split /\n/, $out) {
    $line =~ s/\e\[[0-9;]*m//g;
    push @names, $1 if $line =~ /^Name:\s*(.+?)\s*$/;
  }
  return @names;
}

sub before_generation {
  my ($rc, $out) = run_capture($nix, 'profile', 'history', '--json', '--profile', $profile);
  return "" if $rc != 0;
  return $1 if $out =~ /"id"\s*:\s*([0-9]+)/;
  return "";
}

sub load_cache {
  open my $fh, '<', $cache or die "cache $cache: $!";
  my (@targets, @id_targets, @pins, %name_by_id);
  my $has_id = 0;
  while (my $line = <$fh>) {
    chomp $line;
    my @f = split /\t/, $line;
    next unless @f;
    if ($f[0] eq 'name-id' && defined $f[1] && defined $f[2]) {
      $name_by_id{$f[1]} = $f[2];
    } elsif ($f[0] eq 'target-id') {
      $has_id = 1;
      my $display = $name_by_id{$f[1]} || $f[1];
      my @candidates = map { $name_by_id{$_} || $_ } @f[2 .. $#f];
      @candidates = ($display) unless @candidates;
      push @id_targets, [$display, @candidates];
    } elsif ($f[0] eq 'target') {
      my $display = $f[1];
      my @candidates = @f[2 .. $#f];
      @candidates = ($display) unless @candidates;
      push @targets, [$display, @candidates];
    } elsif ($f[0] eq 'pin-id') {
      push @pins, map { $name_by_id{$_} || $_ } @f[1 .. $#f];
    } elsif ($f[0] eq 'pin') {
      push @pins, @f[1 .. $#f];
    }
  }
  close $fh;
  @targets = @id_targets if $has_id;
  return (\@targets, \@pins);
}

sub norm {
  my ($s) = @_;
  $s =~ s/-[0-9]+$//;
  return $s;
}

sub compute_plan {
  my (@installed) = @_;
  my ($targets, $pins) = load_cache();
  my (%installed, %installed_norm, %desired, %pin);
  for my $name (@installed) {
    $installed{$name} = $name;
    $installed_norm{norm($name)} = $name;
  }
  for my $pin (@$pins) {
    $pin{$pin} = 1;
    $pin{norm($pin)} = 1;
  }
  my (@install, @keep);
  for my $row (@$targets) {
    my $display = $row->[0];
    for my $candidate (@$row) {
      $desired{$candidate} = 1;
      $desired{norm($candidate)} = 1;
    }
    my $found = "";
    for my $candidate (@$row) {
      if (exists $installed{$candidate}) { $found = $installed{$candidate}; last; }
      my $n = norm($candidate);
      if (exists $installed_norm{$n}) { $found = $installed_norm{$n}; last; }
    }
    if ($found ne "") {
      push @keep, $display;
    } else {
      push @install, $display;
    }
  }
  my @remove;
  for my $name (@installed) {
    next if $desired{$name} || $desired{norm($name)};
    next if $pin{$name} || $pin{norm($name)};
    push @remove, $name;
  }
  return (\@install, \@remove, \@keep);
}

sub action_json {
  my ($action, $name) = @_;
  if ($action eq 'install') {
    return '{"action":"install","name":' . js($name) . ',"backend":"nix","target":' . js($name)
      . ',"resolved-target":' . js($name) . ',"installed-name":null,"argv":["profile","install","--profile",'
      . js($profile) . ',' . js("nixpkgs#$name") . ']}';
  }
  return '{"action":"remove","name":' . js($name)
    . ',"backend":"nix","target":null,"resolved-target":null,"installed-name":' . js($name)
    . ',"argv":["profile","remove",' . js($name) . ',"--profile",' . js($profile) . ']}';
}

sub actions_json {
  my ($action, $items) = @_;
  return '[' . join(',', map { action_json($action, $_) } @$items) . ']';
}

sub string_array_json {
  my ($items) = @_;
  return '[' . join(',', map { js($_) } @$items) . ']';
}

sub action_sexp {
  my ($action, $name) = @_;
  if ($action eq 'install') {
    return '(:action install :name ' . sx($name)
      . ' :backend nix :target ' . sx($name)
      . ' :resolved-target ' . sx($name)
      . ' :installed-name nil :argv ("profile" "install" "--profile" '
      . sx($profile) . ' ' . sx("nixpkgs#$name") . '))';
  }
  return '(:action remove :name ' . sx($name)
    . ' :backend nix :target nil :resolved-target nil :installed-name '
    . sx($name) . ' :argv ("profile" "remove" ' . sx($name)
    . ' "--profile" ' . sx($profile) . '))';
}

sub actions_sexp {
  my ($install, $remove) = @_;
  return '(' . join(' ', (map { action_sexp('install', $_) } @$install),
                         (map { action_sexp('remove', $_) } @$remove)) . ')';
}

sub ensure_txn_root {
  return if -d $txn_root;
  my @parts = split m{/+}, $txn_root;
  my $path = $txn_root =~ m{\A/} ? "/" : "";
  for my $part (@parts) {
    next if $part eq "";
    $path .= "/" if $path ne "" && $path ne "/";
    $path .= $part;
    mkdir $path if !-d $path;
  }
}

sub write_record {
  my (%args) = @_;
  ensure_txn_root();
  my $stamp = strftime('%Y%m%dT%H%M%S%z', localtime);
  my $pid = $$;
  my $idx = 1;
  my ($id, $file);
  do {
    $id = "apply-$stamp-$pid-$idx";
    $file = "$txn_root/$id.el";
    $idx++;
  } while (-e $file);
  my $now = strftime('%Y-%m-%dT%H:%M:%S%z', localtime);
  my $before = $args{before_generation};
  my $install = $args{install};
  my $remove = $args{remove};
  my $executed = $args{executed};
  my $status = $args{status};
  my $rollback = $args{rollback};
  my $error = $args{error};
  my $commands = actions_sexp($install, $remove);
  my $executed_s = '(' . join(' ', map { action_sexp($_->[0], $_->[1]) } @$executed) . ')';
  my $installed_s = '(' . join(' ', map { sx($_) } @$install) . ')';
  my $removed_s = '(' . join(' ', map { sx($_) } @$remove) . ')';
  my $rollback_plan = $before ne ""
    ? '(:available t :operation rollback :generation ' . $before
      . ' :argv ("profile" "rollback" "--profile" ' . sx($profile)
      . ' "--to-generation" ' . sx($before) . '))'
    : '(:available nil :reason "before-generation-missing")';
  my $rollback_s = defined($rollback) ? $rollback : 'nil';
  my $error_s = defined($error) ? sx($error) : 'nil';
  my $locked_s = $locked eq "1" ? "t" : "nil";
  my $record = '(:schema "nelix-apply-transaction" :schema-version 1'
    . ' :id ' . sx($id)
    . ' :status ' . $status
    . ' :manifest ' . sx($manifest)
    . ' :profile ' . sx($profile)
    . ' :started-at ' . sx($now)
    . ' :updated-at ' . sx($now)
    . ' :plan (:operation apply :status ' . $status
    . ' :dry-run nil :manifest ' . sx($manifest)
    . ' :lock ' . sx("$manifest.nelix-lock")
    . ' :lock-present ' . ($locked eq "1" ? "t" : "nil")
    . ' :backend nix :backend-selection (:backend nix :fallback :nelisp-aot-cache)'
    . ' :profile "default" :nix-profile ' . sx($profile)
    . ' :install ' . '(' . join(' ', map { action_sexp('install', $_) } @$install) . ')'
    . ' :remove ' . '(' . join(' ', map { action_sexp('remove', $_) } @$remove) . ')'
    . ' :keep nil :protected nil :commands ' . $commands
    . ' :count ' . (scalar(@$install) + scalar(@$remove))
    . ' :empty ' . ((@$install || @$remove) ? "nil" : "t")
    . ' :locked ' . $locked_s
    . ' :lock-enforced ' . $locked_s
    . ' :executed ' . $executed_s
    . ' :installed ' . $installed_s
    . ' :removed ' . $removed_s
    . ')'
    . ' :transaction (:enabled t :backend nix :profile nil :system nil'
    . ' :rollback-on-error t :generation-captured t :rollback-available '
    . ($before ne "" ? "t" : "nil")
    . ' :before-generation ' . sym_or_nil($before)
    . ' :before-generation-error nil'
    . ' :after-generation ' . sym_or_nil($before)
    . ' :record-id ' . sx($id)
    . ' :record-file ' . sx($file)
    . ' :record-started-at ' . sx($now)
    . ' :record-status ' . $status
    . ' :record-updated-at ' . sx($now) . ')'
    . ' :executed ' . $executed_s
    . ' :rollback-plan ' . $rollback_plan
    . ' :rollback ' . $rollback_s
    . ' :error ' . $error_s
    . ')';
  open my $fh, '>', $file or die "write $file: $!";
  print $fh ";;; generated Nelix apply transaction record -*- lexical-binding: t; -*-\n\n$record\n";
  close $fh;
  return ($id, $file);
}

my @installed_names = profile_names();
my ($install, $remove, $keep) = compute_plan(@installed_names);
if ($allow_remove_count eq "" || $allow_remove_count !~ /\A[0-9]+\z/ || scalar(@$remove) != $allow_remove_count) {
  print STDERR "nelix-apply: refusing to remove " . scalar(@$remove) . " package(s); rerun with --allow-remove-count " . scalar(@$remove) . " or --allow-remove\n";
  exit 2;
}

my $before = before_generation();
my @executed;
for my $name (@$install) {
  my $rc = run_status($nix, 'profile', 'install', '--profile', $profile, "nixpkgs#$name");
  if ($rc != 0) {
    my $rollback_rc = $before ne "" ? run_status($nix, 'profile', 'rollback', '--profile', $profile, '--to-generation', $before) : 1;
    my $rollback = '(:attempted t :ok ' . ($rollback_rc == 0 ? 't' : 'nil') . ' :verified ' . ($rollback_rc == 0 ? 't' : 'nil') . ')';
    write_record(status => 'error', install => $install, remove => $remove,
                 executed => \@executed, before_generation => $before,
                 rollback => $rollback, error => "install failed: $name");
    print '{"status":"error","operation":"apply","failed":' . js($name)
      . ',"rollback-message":"rollback=' . ($rollback_rc == 0 ? 'ok' : 'failed') . '"}' . "\n";
    exit 2;
  }
  push @executed, ['install', $name];
}
for my $name (@$remove) {
  my $rc = run_status($nix, 'profile', 'remove', $name, '--profile', $profile);
  if ($rc != 0) {
    my $rollback_rc = $before ne "" ? run_status($nix, 'profile', 'rollback', '--profile', $profile, '--to-generation', $before) : 1;
    my $rollback = '(:attempted t :ok ' . ($rollback_rc == 0 ? 't' : 'nil') . ' :verified ' . ($rollback_rc == 0 ? 't' : 'nil') . ')';
    write_record(status => 'error', install => $install, remove => $remove,
                 executed => \@executed, before_generation => $before,
                 rollback => $rollback, error => "remove failed: $name");
    print '{"status":"error","operation":"apply","failed":' . js($name)
      . ',"rollback-message":"rollback=' . ($rollback_rc == 0 ? 'ok' : 'failed') . '"}' . "\n";
    exit 2;
  }
  push @executed, ['remove', $name];
}

write_record(status => 'ok', install => $install, remove => $remove,
             executed => \@executed, before_generation => $before);

print '{"operation":"apply","status":"ok","locked":' . ($locked eq "1" ? 'true' : 'false')
  . ',"lock-enforced":' . ($locked eq "1" ? 'true' : 'false')
  . ',"installed":' . string_array_json($install)
  . ',"removed":' . string_array_json($remove)
  . ',"install":' . actions_json('install', $install)
  . ',"remove":' . actions_json('remove', $remove)
  . ',"commands":[' . join(',', (map { action_json('install', $_) } @$install),
                              (map { action_json('remove', $_) } @$remove)) . ']'
  . ',"count":' . (scalar(@$install) + scalar(@$remove))
  . ',"backend":"nix","backend-selection":{"backend":"nix","fallback":":nelisp-aot-cache"}}' . "\n";
PERL
  return $?
}

nelix_try_nelisp_aot_cache_fast_lane() {
  nelix_nelisp_aot_cache_enabled || return 1
  if [ "$#" -eq 2 ] && [ "$1" = "--json" ] && [ "$2" = "list" ]; then
    json=1
    command=list
    manifest=
  elif [ "$#" -eq 1 ] && [ "$1" = "list" ]; then
    json=0
    command=list
    manifest=
  elif [ "$#" -eq 4 ] && [ "$1" = "--json" ] && [ "$2" = "apply" ] && [ "$4" = "--dry-run" ]; then
    json=1
    command=apply-dry-run
    manifest=$(nelix_abs_path "$3")
  elif [ "$#" -eq 5 ] && [ "$1" = "--json" ] && [ "$2" = "apply" ] && [ "$4" = "--locked" ] && [ "$5" = "--dry-run" ]; then
    json=1
    command=apply-dry-run-locked
    manifest=$(nelix_abs_path "$3")
  elif [ "$#" -eq 5 ] && [ "$1" = "--json" ] && [ "$2" = "apply" ] && [ "$4" = "--dry-run" ] && [ "$5" = "--locked" ]; then
    json=1
    command=apply-dry-run-locked
    manifest=$(nelix_abs_path "$3")
  elif [ "$#" -eq 6 ] && [ "$1" = "--json" ] && [ "$2" = "apply" ] && [ "$4" = "--locked" ] && [ "$5" = "--allow-remove-count" ]; then
    json=1
    command=apply-real-locked
    manifest=$(nelix_abs_path "$3")
    allow_remove_count=$6
  elif [ "$#" -eq 5 ] && [ "$1" = "--json" ] && [ "$2" = "apply" ] && [ "$4" = "--allow-remove-count" ]; then
    json=1
    command=apply-real
    manifest=$(nelix_abs_path "$3")
    allow_remove_count=$5
  elif [ "$#" -eq 4 ] && [ "$1" = "--json" ] && [ "$2" = "plan" ] && [ "$4" = "--dry-run" ]; then
    json=1
    command=plan
    manifest=$(nelix_abs_path "$3")
  elif [ "$#" -eq 3 ] && [ "$1" = "apply" ] && [ "$3" = "--dry-run" ]; then
    json=0
    command=apply-dry-run
    manifest=$(nelix_abs_path "$2")
  elif [ "$#" -eq 4 ] && [ "$1" = "apply" ] && [ "$3" = "--locked" ] && [ "$4" = "--dry-run" ]; then
    json=0
    command=apply-dry-run-locked
    manifest=$(nelix_abs_path "$2")
  elif [ "$#" -eq 4 ] && [ "$1" = "apply" ] && [ "$3" = "--dry-run" ] && [ "$4" = "--locked" ]; then
    json=0
    command=apply-dry-run-locked
    manifest=$(nelix_abs_path "$2")
  elif [ "$#" -eq 3 ] && [ "$1" = "plan" ] && [ "$3" = "--dry-run" ]; then
    json=0
    command=plan
    manifest=$(nelix_abs_path "$2")
  elif [ "$#" -eq 3 ] && [ "$1" = "--json" ]; then
    json=1
    command=$2
    manifest=$(nelix_abs_path "$3")
  elif [ "$#" -eq 2 ]; then
    json=0
    command=$1
    manifest=$(nelix_abs_path "$2")
  else
    return 1
  fi

  case "$command" in
    list)
      if [ "$json" -eq 1 ]; then
        aot_fun=nelix-aot-list-json
      else
        aot_fun=nelix-aot-list-lines
      fi
      ;;
    audit)
      if [ "$json" -eq 1 ]; then
        aot_fun=nelix-aot-audit-json
      else
        aot_fun=nelix-aot-audit-lines
      fi
      ;;
    plan|apply-dry-run|apply-dry-run-locked|apply-real|apply-real-locked|lock-check)
      aot_fun=
      ;;
    upgrade-plan)
      if [ "$json" -eq 1 ]; then
        aot_fun=nelix-aot-upgrade-plan-json
      else
        aot_fun=nelix-aot-upgrade-plan-lines
      fi
      ;;
    *)
      return 1
      ;;
  esac

  profile=${NELIX_PROFILE_DIR:-$(nelix_default_profile_dir)}
  nix_program=${NELIX_NIX_PROGRAM:-nix}

  if [ "$command" = "list" ]; then
    if [ "$json" -eq 1 ]; then
      command -v jq >/dev/null 2>&1 || return 1
      "$nix_program" profile list --profile "$profile" --json \
        | jq -c '[.elements | to_entries[] |
                  {"name": .key,
                   "attr-path": .value.attrPath,
                   "original-url": .value.originalUrl,
                   "store-paths": (.value.storePaths // [])}]'
    else
      "$nix_program" profile list --profile "$profile" \
        | sed -n 's/\x1b\[[0-9;]*m//g; s/^Name:[[:space:]]*//p'
    fi
    return 0
  fi

  cache="${manifest}.nelix-aot-targets"
  if [ ! -f "$cache" ]; then
    nelix_build_aot_cache "$manifest" || {
      nelix_aot_cache_error missing "$command" "$manifest"
    }
  elif ! nelix_aot_cache_fresh_p "$manifest" "$cache"; then
    nelix_build_aot_cache "$manifest" || {
      nelix_aot_cache_error stale "$command" "$manifest"
    }
  fi
  [ -f "$cache" ] || {
    nelix_aot_cache_error missing "$command" "$manifest"
  }
  nelix_aot_cache_fresh_p "$manifest" "$cache" || {
    nelix_aot_cache_error stale "$command" "$manifest"
  }

  if [ "$command" = "apply-real" ] ||
     [ "$command" = "apply-real-locked" ]; then
    nelix_run_aot_apply_shell_lane "$command" "$json" "$cache" "$profile" "$nix_program" "${allow_remove_count:-}" &&
      return 0
    return 1
  fi

  if nelix_run_aot_id_cache_shell_lane "$command" "$json" "$cache" "$profile" "$nix_program"; then
    return 0
  fi
  if [ "$command" = "plan" ] ||
     [ "$command" = "apply-dry-run" ] ||
     [ "$command" = "apply-dry-run-locked" ]; then
    return 1
  fi

  if [ -f "$lispdir/scripts/nelix-aot-manifest-engine.el" ]; then
    engine=$lispdir/scripts/nelix-aot-manifest-engine.el
  elif [ -f "$lispdir/nelix-aot-manifest-engine.el" ]; then
    engine=$lispdir/nelix-aot-manifest-engine.el
  else
    return 1
  fi

  payload=$(mktemp "${TMPDIR:-/tmp}/nelix-aot-payload.XXXXXX")
  output=$(mktemp "${TMPDIR:-/tmp}/nelix-aot-output.XXXXXX")
  rm -f "$output"

  if ! {
    nelix_emit_aot_cache_runtime_prefix "$cache"
    "$nix_program" profile list --profile "$profile" \
      | sed -n 's/\x1b\[[0-9;]*m//g; s/^Name:[[:space:]]*//p' \
      | awk -F '\t' '
          BEGIN { OFS = "\t" }
          FILENAME == ARGV[1] {
            if ($1 == "name-id" && $2 != "" && $3 != "") {
              ids[$3] = $2
            }
            next
          }
          {
            name = $0
            print "installed", name
            lookup = name
            sub(/-[0-9]+$/, "", lookup)
            if (name in ids) {
              print "installed-id", ids[name]
            } else if (lookup in ids) {
              print "installed-id", ids[lookup]
            }
          }
        ' "$cache" -
    printf 'end\n'
  } >"$payload"; then
    rm -f "$payload" "$output"
    return 1
  fi
  form=$(printf '(progn (load %s) (princ (%s (rdf %s) ":nelisp-aot-cache" %s)) (princ "\n") (quote (:nelix-exit 0)))' \
    "$(nelix_quote_elisp_string "$engine")" \
    "$aot_fun" \
    "$(nelix_quote_elisp_string "$payload")" \
    "$(nelix_quote_elisp_string "$cache")")

  set +e
  "$nelisp_bin" --eval "$form" >"$output"
  status=$?
  set -e
  rm -f "$payload"
  if [ "$status" -ne 0 ] || [ ! -s "$output" ]; then
    rm -f "$output"
    return 1
  fi

  marker=$(sed -n '$p' "$output")
  body=$(sed '$d' "$output")
  rm -f "$output"
  if [ "$marker" != "(:nelix-exit 0)" ]; then
    return 1
  fi
  if [ -n "$body" ]; then
    printf '%s\n' "$body"
  fi
  return 0
}

nelix_run_nelisp_image() {
  image=$1
  shift
  stats_enabled=nil
  if nelix_truthy "${NELIX_NELISP_STATS:-}"; then
    stats_enabled=t
  fi

  probe=$(mktemp "${TMPDIR:-/tmp}/nelix-cli-image-probe.XXXXXX")
  rm -f "$probe"
  probe_form="(progn (nelisp-process-call-process \"/usr/bin/printf\" nil $(nelix_quote_elisp_string "$probe") nil \"%s\" (if (and (fboundp 'nelix-cli-parse-args) (fboundp 'nelix-cli-dispatch) (fboundp 'nelix-cli-format-result)) \"ready\" \"missing\")))"
  set +e
  probe_output=$("$nelisp_bin" eval-runtime-image "$image" "$probe_form")
  probe_status=$?
  set -e
  if [ "$probe_status" -ne 0 ]; then
    printf '%s\n' "$probe_output"
    rm -f "$probe"
    exit "$probe_status"
  fi
  if [ ! -s "$probe" ] || [ "$(cat "$probe")" != "ready" ]; then
    rm -f "$probe"
    echo "nelix: NELIX_NELISP_IMAGE does not contain preloaded Nelix CLI functions" >&2
    exit 2
  fi
  rm -f "$probe"

  runner=$(mktemp "${TMPDIR:-/tmp}/nelix-cli-image.XXXXXX.el")
  result=$(mktemp "${TMPDIR:-/tmp}/nelix-cli-image-result.XXXXXX")
  rm -f "$result"
  trap 'rm -f "$runner" "$result"' EXIT HUP INT TERM
  {
    printf '(setq nelix-cli--direct-home %s)\n' "$(nelix_quote_elisp_string "${HOME:-}")"
    if [ -n "${XDG_STATE_HOME:-}" ]; then
      printf '(setq nelix-transaction-log-root %s)\n' "$(nelix_quote_elisp_string "$XDG_STATE_HOME/nelix/transactions")"
    elif [ -n "${HOME:-}" ]; then
      printf '(setq nelix-transaction-log-root %s)\n' "$(nelix_quote_elisp_string "$HOME/.local/state/nelix/transactions")"
    fi
    printf '(setq nelix-manifest--nelisp-progress-file %s)\n' "$(nelix_quote_elisp_string "${NELIX_PROGRESS_FILE:-}")"
    printf '(setq nelix-fast-aot-force %s)\n' "$(nelix_quote_elisp_string "${NELIX_NELISP_AOT:-}")"
    printf '(setq nelix-cli--direct-result-file %s)\n' "$(nelix_quote_elisp_string "$result")"
    printf '(setq nelix-cli--direct-stats-enabled %s)\n' "$stats_enabled"
    printf '(setq nelix-cli--direct-argv (list\n'
    for arg in "$@"; do
      printf ' %s\n' "$(nelix_quote_elisp_string "$arg")"
    done
    printf '))\n'
    cat <<'EOF'
(when (and (boundp 'nelix-cli--direct-home)
           (stringp nelix-cli--direct-home)
           (> (length nelix-cli--direct-home) 0))
  (when (and (boundp 'anvil-pkg-profile-dir)
             (stringp anvil-pkg-profile-dir)
             (string-prefix-p "~/" anvil-pkg-profile-dir))
    (setq anvil-pkg-profile-dir
          (concat nelix-cli--direct-home
                  (substring anvil-pkg-profile-dir 1))))
  (when (and (boundp 'anvil-pkg-state-file)
             (stringp anvil-pkg-state-file)
             (string-prefix-p "~/" anvil-pkg-state-file))
    (setq anvil-pkg-state-file
          (concat nelix-cli--direct-home
                  (substring anvil-pkg-state-file 1)))))
(defun nelix-cli--direct-write-result (marker text)
  (nelisp-process-call-process
   "/usr/bin/printf"
   nil
   nelix-cli--direct-result-file
   nil
   "%s\n%s\n"
   marker
   text))
(defun nelix-cli--direct-stats (stage)
  (if nelix-cli--direct-stats-enabled
      (if (and (fboundp 'nelisp--write-stderr-line)
               (fboundp 'nelisp--arena-stats))
          (nelisp--write-stderr-line
           (concat "nelix stats stage=" stage " "
                   (prin1-to-string (nelisp--arena-stats))))
        nil)
    nil))
(nelix-cli--direct-stats "entry")
(condition-case err
    (let* ((parsed (progn
                     (nelix-cli--direct-stats "before-parse")
                     (nelix-cli-parse-args nelix-cli--direct-argv)))
           (json (plist-get parsed :json))
           (result (progn
                     (nelix-cli--direct-stats "before-dispatch")
                     (nelix-cli-dispatch parsed)))
           (text (progn
                   (nelix-cli--direct-stats "before-format")
                   (nelix-cli-format-result result json))))
      (nelix-cli--direct-stats "after-format")
      (nelix-cli--direct-write-result "(:nelix-exit 0)" text)
      (nelix-cli--direct-stats "after-write")
      (setq nelix-cli--direct-exit '(:nelix-exit 0)))
  (error
   (nelix-cli--direct-write-result
    "(:nelix-exit 2)"
    (format "nelix: %s" (error-message-string err)))
   (setq nelix-cli--direct-exit '(:nelix-exit 2))))
EOF
  } >"$runner"

  form=$(printf '(progn\n'; cat "$runner"; printf '\nnelix-cli--direct-exit)\n')
  set +e
  output=$("$nelisp_bin" eval-runtime-image "$image" "$form")
  status=$?
  set -e

  if [ "$status" -ne 0 ]; then
    printf '%s\n' "$output"
    rm -f "$runner" "$result"
    trap - EXIT HUP INT TERM
    exit "$status"
  fi
  if [ ! -s "$result" ]; then
    printf '%s\n' "$output"
    rm -f "$runner" "$result"
    trap - EXIT HUP INT TERM
    exit 1
  fi

  marker=$(sed -n '1p' "$result")
  body=$(sed '1d' "$result")
  if [ -n "$body" ]; then
    printf '%s\n' "$body"
  fi
  rm -f "$runner" "$result"
  trap - EXIT HUP INT TERM
  case "$marker" in
    "(:nelix-exit 0)")
      exit 0
      ;;
    "(:nelix-exit 2)")
      exit 2
      ;;
    *)
      printf '%s\n' "$marker"
      exit 1
      ;;
  esac
}

nelix_run_nelisp_direct() {
  if nelix_aot_cache_command_p "$@"; then
    nelix_run_emacs_batch "$@"
  fi
  if nelix_nelisp_validate_fast_lane "$@"; then
    exit 0
  fi

  nelisp_bin=$(nelix_find_nelisp) || {
    echo "nelix: nelisp runtime requested but nelisp was not found" >&2
    exit 127
  }
  nelisp_root=$(nelix_nelisp_root "$nelisp_bin") || {
    echo "nelix: nelisp runtime requested but NELISP_ROOT could not be inferred" >&2
    exit 127
  }

  smoke_file=$(nelix_lisp_file anvil-pkg-nelisp-smoke.el) || {
    echo "nelix: nelisp runtime missing bootstrap file: anvil-pkg-nelisp-smoke.el" >&2
    exit 127
  }
  default_ert_shim=$(nelix_lisp_file anvil-pkg-nelisp-ert-shim.el) || {
    echo "nelix: nelisp runtime missing bootstrap file: anvil-pkg-nelisp-ert-shim.el" >&2
    exit 127
  }
  ert_shim=${NELISP_ERT_SHIM_SRC:-$default_ert_shim}
  stdlib_eval=${NELISP_STDLIB_EVAL_SPECIAL_SRC:-$nelisp_root/lisp/nelisp-stdlib-eval-special.el}
  cl_macros=${NELISP_CL_MACROS_SRC:-$nelisp_root/lisp/nelisp-cl-macros.el}
  json_src=${NELISP_JSON_SRC:-$nelisp_root/packages/nelisp-json/src/nelisp-json.el}
  actor_src=${NELISP_ACTOR_SRC:-$nelisp_root/packages/nelisp-actor/src/nelisp-actor.el}
  process_src=${NELISP_PROCESS_SRC:-$nelisp_root/packages/nelisp-process/src/nelisp-process.el}
  stats_enabled=nil
  if nelix_truthy "${NELIX_NELISP_STATS:-}"; then
    stats_enabled=t
  fi

  for file in "$smoke_file" "$ert_shim" "$stdlib_eval" "$cl_macros" "$json_src" "$actor_src" "$process_src" "$clifile"; do
    if [ ! -f "$file" ]; then
      echo "nelix: nelisp runtime missing bootstrap file: $file" >&2
      exit 127
    fi
  done

  if nelix_try_transaction_fast_lane "$@"; then
    exit 0
  fi

  if nelix_try_nelisp_aot_cache_fast_lane "$@"; then
    exit 0
  fi

  if image=$(nelix_nelisp_cli_image_path); then
    nelix_run_nelisp_image "$image" "$@"
  fi

  runner=$(mktemp "${TMPDIR:-/tmp}/nelix-cli.XXXXXX.el")
  trap 'rm -f "$runner"' EXIT HUP INT TERM
  {
    printf '(setq anvil-pkg-nelisp-smoke-stdlib-eval-special-source %s)\n' "$(nelix_quote_elisp_string "$stdlib_eval")"
    printf '(setq anvil-pkg-nelisp-smoke-cl-macros-source %s)\n' "$(nelix_quote_elisp_string "$cl_macros")"
    printf '(setq anvil-pkg-nelisp-smoke-json-source %s)\n' "$(nelix_quote_elisp_string "$json_src")"
    printf '(setq anvil-pkg-nelisp-smoke-ert-shim-source %s)\n' "$(nelix_quote_elisp_string "$ert_shim")"
    printf '(setq anvil-pkg-nelisp-smoke-actor-source %s)\n' "$(nelix_quote_elisp_string "$actor_src")"
    printf '(setq anvil-pkg-nelisp-smoke-process-source %s)\n' "$(nelix_quote_elisp_string "$process_src")"
    printf '(setq nelix-cli--direct-home %s)\n' "$(nelix_quote_elisp_string "${HOME:-}")"
    if [ -n "${XDG_STATE_HOME:-}" ]; then
      printf '(setq nelix-transaction-log-root %s)\n' "$(nelix_quote_elisp_string "$XDG_STATE_HOME/nelix/transactions")"
    elif [ -n "${HOME:-}" ]; then
      printf '(setq nelix-transaction-log-root %s)\n' "$(nelix_quote_elisp_string "$HOME/.local/state/nelix/transactions")"
    fi
    printf '(setq nelix-manifest--nelisp-progress-file %s)\n' "$(nelix_quote_elisp_string "${NELIX_PROGRESS_FILE:-}")"
    printf '(setq nelix-fast-aot-force %s)\n' "$(nelix_quote_elisp_string "${NELIX_NELISP_AOT:-}")"
    printf '(setq nelix-cli--direct-stats-enabled %s)\n' "$stats_enabled"
    printf '(setq nelix-cli--direct-argv (list\n'
    for arg in "$@"; do
      printf ' %s\n' "$(nelix_quote_elisp_string "$arg")"
    done
    printf '))\n'
    printf '(load %s)\n' "$(nelix_quote_elisp_string "$smoke_file")"
    cat <<'EOF'
(defun nelix-cli--direct-stats (stage)
  (if nelix-cli--direct-stats-enabled
      (if (and (fboundp 'nelisp--write-stderr-line)
               (fboundp 'nelisp--arena-stats))
          (nelisp--write-stderr-line
           (concat "nelix stats stage=" stage " "
                   (prin1-to-string (nelisp--arena-stats))))
        nil)
    nil))
(nelix-cli--direct-stats "after-smoke")
EOF
    nelix_emit_nelisp_suite_source_files
    printf '(anvil-pkg-nelisp-smoke-preload-suite-runtime)\n'
    printf '(nelix-cli--direct-stats "after-preload")\n'
    printf '(load %s)\n' "$(nelix_quote_elisp_string "$clifile")"
    printf '(nelix-cli--direct-stats "after-cli-load")\n'
    cat <<'EOF'
(defun nelix-cli--direct-call-process (program args)
  (let ((stdout-file (make-temp-file "nelix-direct-stdout-"))
        (resolved (or (anvil-pkg-compat-executable-find program) program)))
    (unwind-protect
        (let ((exit (apply #'nelisp-process-call-process
                           resolved nil stdout-file nil args)))
          (list :exit (if (numberp exit) exit -1)
                :stdout (anvil-pkg-compat-read-file stdout-file)
                :stderr ""))
      (anvil-pkg-compat-delete-file-quietly stdout-file))))

(when (fboundp 'nelisp-process-call-process)
  (setq anvil-pkg-compat-nelisp-call-process-function
        #'nelix-cli--direct-call-process))

(when (and (boundp 'nelix-cli--direct-home)
           (stringp nelix-cli--direct-home)
           (> (length nelix-cli--direct-home) 0))
  (when (and (boundp 'anvil-pkg-profile-dir)
             (stringp anvil-pkg-profile-dir)
             (string-prefix-p "~/" anvil-pkg-profile-dir))
    (setq anvil-pkg-profile-dir
          (concat nelix-cli--direct-home
                  (substring anvil-pkg-profile-dir 1))))
  (when (and (boundp 'anvil-pkg-state-file)
             (stringp anvil-pkg-state-file)
             (string-prefix-p "~/" anvil-pkg-state-file))
    (setq anvil-pkg-state-file
          (concat nelix-cli--direct-home
                  (substring anvil-pkg-state-file 1)))))
(condition-case err
    (let* ((parsed (progn
                     (nelix-cli--direct-stats "before-parse")
                     (nelix-cli-parse-args nelix-cli--direct-argv)))
           (json (plist-get parsed :json))
           (result (progn
                     (nelix-cli--direct-stats "before-dispatch")
                     (nelix-cli-dispatch parsed)))
           (text (progn
                   (nelix-cli--direct-stats "before-format")
                   (nelix-cli-format-result result json))))
      (nelix-cli--direct-stats "after-format")
      (princ text)
      (princ "\n")
      (nelix-cli--direct-stats "after-print")
      (setq nelix-cli--direct-exit '(:nelix-exit 0)))
  (error
   (princ (format "nelix: %s\n" (error-message-string err)))
   (setq nelix-cli--direct-exit '(:nelix-exit 2))))
EOF
  } >"$runner"

  set +e
  output=$("$nelisp_bin" --eval "(progn (load $(nelix_quote_elisp_string "$runner")) nelix-cli--direct-exit)")
  status=$?
  set -e
  rm -f "$runner"
  trap - EXIT HUP INT TERM

  if [ "$status" -ne 0 ]; then
    printf '%s\n' "$output"
    exit "$status"
  fi

  marker=$(printf '%s\n' "$output" | tail -n 1)
  body=$(printf '%s\n' "$output" | sed '$d')
  if [ -n "$body" ]; then
    printf '%s\n' "$body"
  fi
  case "$marker" in
    "(:nelix-exit 0)")
      exit 0
      ;;
    "(:nelix-exit 2)")
      exit 2
      ;;
    *)
      printf '%s\n' "$marker"
      exit 1
      ;;
  esac
}

case "$runtime" in
  nelisp)
    nelix_run_nelisp_direct "$@"
    ;;
  auto)
    if nelix_nelisp_direct_available; then
      nelix_run_nelisp_direct "$@"
    fi
    ;;
  emacs)
    ;;
  *)
    echo "nelix: unknown runtime '$runtime' (expected emacs, nelisp, or auto)" >&2
    exit 2
    ;;
esac

nelix_run_emacs_batch "$@"
