{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nelix.example.invalid/schema/nelix-manifest-dsl-v1.schema.json",
  "title": "Nelix manifest DSL schema v1 summary",
  "type": "object",
  "required": [
    "name",
    "schema",
    "schema-version",
    "entrypoint",
    "json-schema",
    "forms",
    "manifest-keys",
    "form-map",
    "backends",
    "backend-policy",
    "package-forms",
    "package-options",
    "package-option-types",
    "package-row-required",
    "package-row-semantics",
    "version-pin",
    "remove-policy-values",
    "deferred-forms",
    "forbidden-forms",
    "remove-policy",
    "classification",
    "platform-conditions",
    "private-data",
    "stable"
  ],
  "properties": {
    "name": {
      "const": "manifest-dsl-v1"
    },
    "schema": {
      "const": "nelix-environment"
    },
    "schema-version": {
      "const": 1
    },
    "entrypoint": {
      "const": "nelix-environment"
    },
    "json-schema": {
      "const": "docs/schema/nelix-manifest-dsl-v1.schema.json"
    },
    "forms": {
      "type": "array",
      "const": [
        "name",
        "profile",
        "nix-channel",
        "imports",
        "backend-policy",
        "emacs-packages",
        "linux-packages",
        "debian-tools",
        "bootstrap-apt-packages",
        "pins",
        "package",
        "linux-package",
        "version-pin",
        "remove-policy"
      ],
      "items": {
        "enum": [
          "name",
          "profile",
          "nix-channel",
          "imports",
          "backend-policy",
          "emacs-packages",
          "linux-packages",
          "debian-tools",
          "bootstrap-apt-packages",
          "pins",
          "package",
          "linux-package",
          "version-pin",
          "remove-policy"
        ]
      }
    },
    "manifest-keys": {
      "type": "array",
      "const": [
        "name",
        "profile",
        "nix-channel",
        "imports",
        "backend-policy",
        "emacs",
        "linux",
        "debian-tools",
        "bootstrap-apt",
        "pins",
        "package-rows",
        "linux-package-rows",
        "version-pins",
        "remove-policy"
      ],
      "items": {
        "enum": [
          "name",
          "profile",
          "nix-channel",
          "imports",
          "backend-policy",
          "emacs",
          "linux",
          "debian-tools",
          "bootstrap-apt",
          "pins",
          "package-rows",
          "linux-package-rows",
          "version-pins",
          "remove-policy"
        ]
      }
    },
    "form-map": {
      "type": "array",
      "const": [
        {
          "form": "name",
          "manifest-key": "name"
        },
        {
          "form": "profile",
          "manifest-key": "profile"
        },
        {
          "form": "nix-channel",
          "manifest-key": "nix-channel"
        },
        {
          "form": "imports",
          "manifest-key": "imports"
        },
        {
          "form": "backend-policy",
          "manifest-key": "backend-policy"
        },
        {
          "form": "emacs-packages",
          "manifest-key": "emacs"
        },
        {
          "form": "linux-packages",
          "manifest-key": "linux"
        },
        {
          "form": "debian-tools",
          "manifest-key": "debian-tools"
        },
        {
          "form": "bootstrap-apt-packages",
          "manifest-key": "bootstrap-apt"
        },
        {
          "form": "pins",
          "manifest-key": "pins"
        },
        {
          "form": "package",
          "manifest-key": "package-rows"
        },
        {
          "form": "linux-package",
          "manifest-key": "linux-package-rows"
        },
        {
          "form": "version-pin",
          "manifest-key": "version-pins"
        },
        {
          "form": "remove-policy",
          "manifest-key": "remove-policy"
        }
      ],
      "items": {
        "$ref": "#/$defs/form-map-row"
      }
    },
    "backends": {
      "type": "array",
      "const": [
        "nelix-native",
        "nix",
        "apt",
        "dnf",
        "git",
        "elpa",
        "homebrew",
        "scoop",
        "winget"
      ],
      "items": {
        "enum": [
          "nelix-native",
          "nix",
          "apt",
          "dnf",
          "git",
          "elpa",
          "homebrew",
          "scoop",
          "winget"
        ]
      }
    },
    "backend-policy": {
      "const": "backend-symbols-or-os-rows"
    },
    "package-forms": {
      "type": "array",
      "const": [
        "package",
        "linux-package"
      ],
      "items": {
        "enum": [
          "package",
          "linux-package"
        ]
      }
    },
    "package-options": {
      "type": "array",
      "const": [
        ":backend",
        ":pin",
        ":version",
        ":profile",
        ":group",
        ":feature",
        ":platform",
        ":when"
      ],
      "items": {
        "enum": [
          ":backend",
          ":pin",
          ":version",
          ":profile",
          ":group",
          ":feature",
          ":platform",
          ":when"
        ]
      }
    },
    "package-option-types": {
      "type": "array",
      "const": [
        {
          "option": ":backend",
          "type": "backend-symbol"
        },
        {
          "option": ":pin",
          "type": "boolean"
        },
        {
          "option": ":version",
          "type": "string-or-symbol"
        },
        {
          "option": ":profile",
          "type": "string-or-symbol"
        },
        {
          "option": ":group",
          "type": "string-or-symbol"
        },
        {
          "option": ":feature",
          "type": "string-or-symbol"
        },
        {
          "option": ":platform",
          "type": "string-or-symbol-or-list"
        },
        {
          "option": ":when",
          "type": "symbol-or-list"
        }
      ],
      "items": {
        "$ref": "#/$defs/package-option-type-row"
      }
    },
    "package-row-required": {
      "type": "array",
      "const": [
        "kind",
        "name"
      ],
      "items": {
        "enum": [
          "kind",
          "name"
        ]
      }
    },
    "package-row-semantics": {
      "const": "metadata-plus-target-list"
    },
    "version-pin": {
      "const": "metadata-plus-pin-name"
    },
    "remove-policy-values": {
      "type": "array",
      "const": [
        "confirm",
        "keep",
        "prune"
      ],
      "items": {
        "enum": [
          "confirm",
          "keep",
          "prune"
        ]
      }
    },
    "deferred-forms": {
      "type": "array",
      "const": [
        "group",
        "feature",
        "platform",
        "platform-when"
      ],
      "items": {
        "enum": [
          "group",
          "feature",
          "platform",
          "platform-when"
        ]
      }
    },
    "forbidden-forms": {
      "type": "array",
      "const": [
        "secret",
        "secrets",
        "private-repo",
        "private-repos",
        "credential",
        "credentials",
        "token",
        "access-token",
        "auth-header"
      ],
      "items": {
        "enum": [
          "secret",
          "secrets",
          "private-repo",
          "private-repos",
          "credential",
          "credentials",
          "token",
          "access-token",
          "auth-header"
        ]
      }
    },
    "remove-policy": {
      "const": "manifest-declares-cli-still-confirms"
    },
    "classification": {
      "const": "package-options-group-feature"
    },
    "platform-conditions": {
      "const": "package-option-platform-metadata"
    },
    "private-data": {
      "const": "forbidden"
    },
    "stable": {
      "const": true
    }
  },
  "additionalProperties": true,
  "$defs": {
    "form-map-row": {
      "type": "object",
      "required": [
        "form",
        "manifest-key"
      ],
      "properties": {
        "form": {
          "type": "string"
        },
        "manifest-key": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "package-option-type-row": {
      "type": "object",
      "required": [
        "option",
        "type"
      ],
      "properties": {
        "option": {
          "enum": [
            ":backend",
            ":pin",
            ":version",
            ":profile",
            ":group",
            ":feature",
            ":platform",
            ":when"
          ]
        },
        "type": {
          "enum": [
            "backend-symbol",
            "boolean",
            "string-or-symbol",
            "string-or-symbol-or-list",
            "symbol-or-list"
          ]
        }
      },
      "additionalProperties": false
    }
  }
}
